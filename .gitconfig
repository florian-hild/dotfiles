## Local .gitconfig example

# [user]
#   name = Florian Hild
#   email = florian.hild@...
#   signingKey = key_name

# [commit]
#   gpgSign = true

# [include]
#   path = ~/.dotfiles/.gitconfig


[core]
    editor = vim
    pager = less -FRX
    # Linux
    autocrlf = input
    # Windows
    #autocrlf = true
    safecrlf = false
    whitespace = fix,trailing-space,-space-before-tab,tab-in-indent,cr-at-eol
[pull]
    ff = only
    rebase = merges
[merge]
    ff = false
[diff]
    colorMoved = default
[color]
    ui = auto
[color "status"]
    added = green bold
    changed = yellow bold
    untracked = red bold
[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold
    whitespace = red reverse
[alias]
    a = add -v
    alias = config --get-regexp ^alias
    amend = commit --amend --no-edit
    b = branch -va
    # Branch overview as table (BSD/macOS column compatible)
    bb = "!{ printf '\\033[31mAhead\\tBehind\\t\\033[34mBranch\\t\\033[33mLast Commit\\t\\033[mDescription\\n'; git for-each-ref --color=always --sort=-committerdate --format='%(color:red)%(ahead-behind:HEAD)%09%(color:blue)%(refname:short)%09%(color:yellow)%(committerdate:relative)%09%(color:reset)%(if)%(describe)%(then)%(describe)%(else)-%(end)' refs/heads | sed \"s/ /$(printf '\\t')/\"; } | column -t -s \"$(printf '\\t')\""
    cm = commit -m
    co = checkout
    d = diff --staged --color
    # Delete local branches whose upstream is gone (locale-independent)
    db = "!git fetch --all --prune && git for-each-ref --format '%(upstream:track);%(worktreepath);%(refname:short)' refs/heads | awk -F ';' '$1 == \"[gone]\" && $2 == \"\" { print $3 }' | xargs git branch -D"
    dh = diff HEAD
    f = fetch --all -Pp
    lg = log --all --color --graph --abbrev-commit --pretty=format:'%C(yellow)%h %Cred%ad %Cblue%an%Cgreen%d %Creset%s' --date=format:'%Y-%m-%d %H:%M'
    lgf = log --all --color --graph --abbrev-commit --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --date=relative -p
    lgg = log  --all --color --graph --abbrev-commit --pretty=format:'%C(yellow)%h %Cred%ad %Cblue%an%Cgreen%d %Creset%s' --date=format:'%Y-%m-%d %H:%M' --name-status
    pb = push -u origin HEAD
    pf = push --force-with-lease --force-if-includes
    pl = pull --rebase
    # Rebase current branch onto origin's default branch (fallback: origin/main)
    rbm = "!git fetch origin && git rebase $(git symbolic-ref -q --short refs/remotes/origin/HEAD 2>/dev/null || echo origin/main)"
    st = status --short
    staash = stash --all
    w = worktree
    wl = worktree list
    wr = worktree remove
[rerere]
    enabled = true
[init]
    defaultBranch = main
[fetch]
    prune = true
[push]
    autoSetupRemote = true
[credential "https://github.com"]
    helper = !gh auth git-credential
[credential "https://gist.github.com"]
    helper = !gh auth git-credential
[branch]
    sort = -committerdate
[gpg]
    program = gpg
[rebase]
    updateRefs = true
    autoStash = true
