.vim/.netrwhist

# Ignore GIT files
.worktree/
# Created by git for backups.
*.orig
# Created by git when using merge tools for conflicts
*.BACKUP.*
*.BASE.*
*.LOCAL.*
*.REMOTE.*
*_BACKUP_*.txt
*_BASE_*.txt
*_LOCAL_*.txt
*_REMOTE_*.txt


# Ignore files created by Python
.venv/
venv/
__pycache__/
*.py[codz]
*$py.class
.pytest_cache/
.ruff_cache/

# Ignore OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Icon?
*.stackdump
*.swp
.cache/
known_hosts
nohup.out
$RECYCLE.BIN/
[Dd]esktop.ini
*~

# Ignore files created by IDE's
.vscode/
.devcontainer*
.theia/
.idea/
.Trash*
*.iml
.metadata
.settings/
.loadpath
.recommenders
.externalToolBuilders/
*.launch
*.pydevproject
.cproject
.autotools
.factorypath
.buildpath
.target
.tern-project
.springBeans
.apt_generated/
.apt_generated_test/
.cache-main
.scala_dependencies
.worksheet
.sts4-cache/
.navigation/
captures/
**/nbproject/private/
**/nbproject/Makefile-*.mk
**/nbproject/Package-*.bash
nbbuild/
dist/
nbdist/
.nb-gradle/
/out/

# Ignore compiled source
*.class
*.com
*.dll
*.exe
*.o
*.so.*
*.rpm
*.ko
*.obj
*.gch
*.pch
*.lib
*.a
*.la
*.lo
*.dylib
*.out
*.app
*.dSYM/
*.su
*.idb
*.pdb
# Jasper files are created by Jasper when printing a jrxml file for the first time and contain the "precompiled" report
*.jasper

# Ignore generated files
bin/
gen/
out/
generated/
copied/
tmp/
*.tmp
*.bak
*~.nib
proguard/

# Ignore logs and databases
*.log
*.log.*
*.sql
*.sqlite
*.db*

# Ignore packages
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
# Exception for gradle wrapper jar, which is needed to build the project
!gradle-wrapper.jar
*.rar
*.tar
*.tar.gz
*.tgz
*.zip
