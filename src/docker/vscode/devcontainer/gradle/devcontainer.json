{
    "name": "gradle-dev-container",
    "dockerFile": "Dockerfile",
    "containerEnv": {
        "MAVEN_DOWNLOAD_URL": "${localEnv:MAVEN_DOWNLOAD_URL}",
        "MAVEN_USER": "${localEnv:MAVEN_USER}",
        "MAVEN_PASSWORD": "${localEnv:MAVEN_PASSWORD}"
    },
    "mounts": [
        {
            "source": "/etc/localtime",
            "target": "/etc/localtime",
            "type": "bind"
        },
        {
            "source": "${env:DOT}/docker/vscode/devcontainer/dotfiles/.bashrc",
            "target": "/root/.bashrc",
            "type": "bind"
        }
    ],
    "runArgs": [
        "--name=vscode-dev-container-gradle"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "vscode.makefile-tools",
                "yzhang.markdown-all-in-one",
                "eamodio.gitlens",
                "vscjava.vscode-gradle"
            ]
        }
    }
}
