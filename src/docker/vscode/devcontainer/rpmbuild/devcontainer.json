{
    "name": "rpmbuild-dev-container",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "options": [
            "--platform=linux/amd64"
        ]
    },
    "runArgs": [
        "--name=vscode-dev-container-thirdparty-rpms"
    ],
    "remoteEnv": {
        "LANG": "C.UTF-8",
        "TZ": "Europe/Berlin",
        "CI": "true"
    },
    "mounts": [
        {
            "source": "/etc/localtime",
            "target": "/etc/localtime",
            "type": "bind"
        }
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.makefile-tools",
                "RVSmartPorting.rpm-spec-ext",
                "bierner.github-markdown-preview",
                "eamodio.gitlens"
            ]
        }
    }
}
